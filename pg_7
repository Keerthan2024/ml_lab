import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

from sklearn.model_selection import train_test_split
from sklearn.preprocessing import PolynomialFeatures, StandardScaler
from sklearn.linear_model import LinearRegression
from sklearn.pipeline import make_pipeline
from sklearn.metrics import mean_squared_error

# Dataset URL
auto_mpg_url = "https://archive.ics.uci.edu/ml/machine-learning-databases/auto-mpg/auto-mpg.data"

# Column names
column_names = [
    'mpg', 'cylinders', 'displacement',
    'horsepower', 'weight', 'acceleration',
    'model_year', 'origin'
]

# Load dataset
auto_df = pd.read_csv(
    auto_mpg_url,
    delim_whitespace=True,
    names=column_names,
    na_values='?'
)

# Remove null values
auto_df = auto_df.dropna()

# Feature and target
X_auto = auto_df[['horsepower']].astype(float).values
y_auto = auto_df['mpg'].values

# Split dataset
X_train, X_test, y_train, y_test = train_test_split(
    X_auto, y_auto, test_size=0.2, random_state=42
)

# Polynomial model
poly_model = make_pipeline(
    PolynomialFeatures(degree=3),
    StandardScaler(),
    LinearRegression()
)

# Train model
poly_model.fit(X_train, y_train)

# Prediction
y_poly_pred = poly_model.predict(X_test)

# Sort values for smooth curve
X_test_sorted, y_poly_pred_sorted = zip(
    *sorted(zip(X_test.flatten(), y_poly_pred))
)

# Plot graph
plt.figure(figsize=(10, 5))

plt.scatter(X_test, y_test, color='blue', label='Actual')
plt.plot(
    X_test_sorted,
    y_poly_pred_sorted,
    color='red',
    linewidth=2,
    label='Predicted'
)

plt.xlabel("Horsepower")
plt.ylabel("MPG")
plt.title("Polynomial Regression on Auto MPG Dataset")

plt.legend()
plt.show()

# Error
print("Mean Squared Error (Polynomial Regression):",
      mean_squared_error(y_test, y_poly_pred))
